-- Template for a custom FUObjectHashTables::Get() signature (rename to
-- GUObjectHashTables.lua to use). The pattern below is a placeholder and
-- will NOT work as-is: derive a real one from the game binary by locating
-- FUObjectHashTables::Get (commonly referenced from StaticFindObject and
-- the object hashing functions).

function Register()
    return "48 8B ?? ?? ?? ?? ?? 48 85 C0 75 ?? 8D"
end

function OnMatchFound(MatchAddress)
    -- Return the address of FUObjectHashTables::Get (or resolve the
    -- RIP-relative operand if the pattern lands on a call/lea).
    return MatchAddress
end
